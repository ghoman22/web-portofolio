<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="dark light">
    
    <!-- SEO Meta Tags -->
    <title>Page Not Found (404) | Firman Arya - DevOps Engineer</title>
    <meta name="description" content="The page you're looking for doesn't exist. Browse our DevOps blog, portfolio, and tutorials on AWS, Kubernetes, and CI/CD pipelines.">
    <meta name="robots" content="noindex, follow">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="https://goman.ngenz.org/404">
    
    <!-- Favicon and Icons -->
    <link rel="icon" type="image/x-icon" href="favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="favicon.ico">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="styles.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Fira+Code&display=swap" rel="stylesheet">
    
    <style>
        .error-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-color);
            color: var(--text-color);
            text-align: center;
            padding: 2rem;
        }
        
        .error-content {
            max-width: 600px;
        }
        
        .error-code {
            font-size: 8rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }
        
        .error-title {
            font-size: 2rem;
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .error-description {
            font-size: 1.1rem;
            margin-bottom: 2rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }
        
        .error-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .error-links {
            margin-top: 3rem;
        }
        
        .error-links h3 {
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .link-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }
        
        .link-card {
            background: var(--card-bg);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            text-decoration: none;
            color: var(--text-color);
            transition: all 0.3s ease;
        }
        
        .link-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary-color);
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.1);
        }
        
        .link-card i {
            font-size: 2rem;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
        }
        
        .link-card h4 {
            margin-bottom: 0.5rem;
            font-size: 1.1rem;
        }
        
        .link-card p {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin: 0;
        }
    </style>
</head>

<body class="dark">
    <!-- Animated Background Particles -->
    <div class="particles-bg">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>

    <div class="error-page">
        <div class="error-content">
            <div class="error-code">404</div>
            <h1 class="error-title">Page Not Found</h1>
            <p class="error-description">
                The page you're looking for seems to have vanished into the cloud. 
                But don't worry, our infrastructure is still running smoothly!
            </p>
            
            <div class="error-actions">
                <a href="/" class="btn btn-primary">
                    <i class="fas fa-home"></i>
                    Go Home
                </a>
                <a href="/blog" class="btn btn-secondary">
                    <i class="fas fa-blog"></i>
                    Browse Blog
                </a>
            </div>
            
            <div class="error-links">
                <h3>Popular Pages</h3>
                <div class="link-grid">
                    <a href="/" class="link-card">
                        <i class="fas fa-user"></i>
                        <h4>Portfolio</h4>
                        <p>About me and my experience</p>
                    </a>
                    
                    <a href="/blog" class="link-card">
                        <i class="fas fa-blog"></i>
                        <h4>DevOps Blog</h4>
                        <p>Tutorials and insights</p>
                    </a>
                    
                    <a href="/blog/ci-cd-pipeline-github-actions" class="link-card">
                        <i class="fas fa-cogs"></i>
                        <h4>CI/CD Guide</h4>
                        <p>GitHub Actions tutorial</p>
                    </a>
                    
                    <a href="/blog/aws-terraform-infrastructure" class="link-card">
                        <i class="fas fa-cloud"></i>
                        <h4>AWS + Terraform</h4>
                        <p>Infrastructure as Code</p>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>

</html>